{
  "name": "audaztacticalweb",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/inject-firestore-admin.mjs && node scripts/inject-fcm-sw.mjs && vite",
    "build": "node scripts/inject-fcm-sw.mjs && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy-backend": "node scripts/inject-firestore-admin.mjs && firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:registration": "firebase deploy --only functions:registerOperatorProfile",
    "deploy:storage": "firebase deploy --only storage",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:functions": "node scripts/inject-functions-env.mjs && firebase deploy --only functions",
    "deploy:functions:admin": "firebase deploy --only functions:ensureAdminClaim,functions:claimInstructorRole",
    "open:auth-providers": "firebase open auth",
    "sync-firestore-rules": "node scripts/inject-firestore-admin.mjs",
    "admin:upgrade-trial": "node scripts/admin_upgrade.js --lock-expired",
    "admin:upgrade-trial:dry": "node scripts/admin_upgrade.js --lock-expired --dry-run",
    "admin:upgrade-premium": "node scripts/admin_upgrade.js --upgrade-premium",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.6",
    "@capacitor/cli": "^7.6.6",
    "@capacitor/core": "^7.6.6",
    "@capacitor/ios": "^7.6.6",
    "browser-image-compression": "^2.0.2",
    "firebase": "^12.12.0",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.8.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "firebase-tools": "^13.35.1",
    "globals": "^16.4.0",
    "tailwindcss": "^4.2.2",
    "vite": "^6.2.0"
  }
}
