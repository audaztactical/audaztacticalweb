rules_version = '2';
// NOT: E-posta/şifre veya Google girişi BURADAN açılmaz — Firestore yalnızca veri erişimini kısıtlar.
// Sign-in method: Firebase Console → Authentication → Sign-in method (veya: npm run open:auth-providers)
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Yönetici: VITE_ADMIN_EMAIL (.env.local) ile aynı olmalıdır.
     * Deploy öncesi: npm run deploy-backend veya node scripts/inject-firestore-admin.mjs
     * %%ADMIN_EMAIL_LOWER%% yerine otomatik yazılır (firestore.deploy.rules).
     */
    function isContentAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true
        || (
          request.auth.token.email != null
          && request.auth.token.email.lower() == '%%ADMIN_EMAIL_LOWER%%'
        )
      );
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerUid(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    /** users/{uid}.role === 'instructor' (Eğitmen Paneli) */
    function isInstructor() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && authMuhabereRole() == 'instructor';
    }

    function canAccessOperatorData(operatorUid) {
      return isOwnerUid(operatorUid) || isInstructor() || isContentAdmin();
    }

    /** users/{uid} — role veya legacy userRole */
    function userRoleFromData(data) {
      return 'role' in data ? data.role : ('userRole' in data ? data.userRole : '');
    }

    function userMuhabereRole() {
      return userRoleFromData(resource.data);
    }

    /** Oturum açmış kullanıcının users/{uid} belgesinden rol (create vb. resource=null bağlamları). */
    function authMuhabereRole() {
      return userRoleFromData(
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data,
      );
    }

    function isOperativeMemberRole(role) {
      return role == 'operator' || role == 'member' || role == 'premium_member';
    }

    function isMuhabereVisibleUser() {
      let role = userMuhabereRole();
      return isOperativeMemberRole(role) || role == 'instructor';
    }

    function isAuthMuhabereVisibleUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (isOperativeMemberRole(authMuhabereRole()) || authMuhabereRole() == 'instructor');
    }

    /** Oturum açmış kullanıcının users/{uid} verisi */
    function authUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /** accountStatus == suspended ve süre dolmamış (suspendedUntil null = süresiz). */
    function isCurrentlySuspended() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && authUserDoc().get('accountStatus', 'active') == 'suspended'
        && (
          !('suspendedUntil' in authUserDoc())
          || authUserDoc().suspendedUntil == null
          || authUserDoc().suspendedUntil > request.time
        );
    }

    function isNotSuspended() {
      return !isCurrentlySuspended();
    }

    function userRoleOf(data) {
      return userRoleFromData(data);
    }

    /** Kendi profilinde ayrıcalıklı alanlar istemciden değiştirilemez (Admin SDK / Cloud Functions). */
    function ownerPrivilegedFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role', 'userRole', 'accountStatus', 'premiumPaymentId', 'premiumUpgradedAt',
        'suspendedUntil', 'suspensionReason'
      ]);
    }

    /** İlk kayıt: yalnızca standart operatör rolleri; premium alanları yasak. */
    function validselfRegistrationRole() {
      let role = userRoleOf(request.resource.data);
      return (role == 'operator' || role == 'member' || role == '')
        && request.resource.data.get('accountStatus', 'active') == 'active'
        && !('premiumPaymentId' in request.resource.data)
        && !('premiumUpgradedAt' in request.resource.data);
    }

    /** Protokol onayı — yalnızca agreedToTerms alanları (profil henüz yoksa). */
    function isOwnerTermsAckOnly() {
      return request.resource.data.keys().hasOnly(['agreedToTerms', 'termsAgreedAt', 'updatedAt'])
        && request.resource.data.agreedToTerms == true;
    }

    /** Muhabere çevrimiçi durumu — yalnızca lastSeenAt / isOnline (presence heartbeat). */
    function isOwnerPresenceOnlyUpdate(uid) {
      return isOwnerUid(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeenAt', 'isOnline']);
    }

    /** FCM cihaz token'ları — yalnızca fcmTokens / fcmTokenUpdatedAt / legacy fcmToken temizliği. */
    function isOwnerFcmTokensOnlyUpdate(uid) {
      return isOwnerUid(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fcmTokens', 'fcmTokenUpdatedAt', 'fcmToken'
        ]);
    }

    /**
     * Taktik Muhabere — engellenen operatörler (yalnızca kendi profili).
     * arrayUnion / arrayRemove: liste yalnızca büyür veya küçülür; kendi uid eklenemez.
     */
    function isOwnerBlockedUsersOnlyUpdate(uid) {
      let prior = resource.data.get('blockedUsers', []);
      let next = request.resource.data.get('blockedUsers', []);
      return isOwnerUid(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['blockedUsers'])
        && next is list
        && next.size() <= 256
        && !(request.auth.uid in next)
        && (
          (next.hasAll(prior) && next.size() >= prior.size())
          || (prior.hasAll(next) && prior.size() >= next.size())
        );
    }

    /** DM mesajı — alıcı okundu işaretler (status/read + readBy arrayUnion). */
    function isMuhabereMessageMarkedReadByReceiver() {
      return resource.data.receiverId == request.auth.uid
        && request.resource.data.status == 'read'
        && request.resource.data.read == true
        && request.resource.data.readBy is list
        && request.auth.uid in request.resource.data.readBy
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'read', 'readBy']);
    }

    match /users/{userId} {
      allow read: if isOwnerUid(userId)
        || isContentAdmin()
        || (isInstructor() && isOperativeMemberRole(resource.data.get('role', resource.data.get('userRole', ''))))
        || (isSignedIn() && isMuhabereVisibleUser());
      allow list: if isContentAdmin()
        || isInstructor()
        || (isSignedIn() && isAuthMuhabereVisibleUser());
      allow create: if isOwnerUid(userId) && (validselfRegistrationRole() || isOwnerTermsAckOnly());
      allow update: if isContentAdmin()
        || isMuhaberePeerContactLink(userId)
        || isMuhaberePeerContactUnlink(userId)
        || (isOwnerUid(userId) && !exists(/databases/$(database)/documents/users/$(userId)) && validselfRegistrationRole())
        || (isOwnerUid(userId) && isOwnerTermsAckOnly())
        || (isOwnerUid(userId) && isOwnerPresenceOnlyUpdate(userId))
        || (isOwnerUid(userId) && isOwnerFcmTokensOnlyUpdate(userId))
        || (isOwnerUid(userId) && isOwnerBlockedUsersOnlyUpdate(userId))
        || (isOwnerUid(userId) && ownerPrivilegedFieldsUnchanged());
      allow delete: if false;
    }

    /** @deprecated — health_records/{uid} kullanın; salt okuma (migration). */
    match /health_profiles/{userId} {
      allow read: if isOwnerUid(userId);
      allow write: if false;
    }

    /** Taktik Muhabere — kullanıcı kanal okuma durumu (lastReadAt) */
    match /users/{userId}/muhabere_channel_reads/{channelId} {
      allow read, write: if isOwnerUid(userId);
    }

    /** Taktik Muhabere — sunucu tarafı kanal özeti (syncMuhabereChannelSummary) */
    match /users/{userId}/muhabere_summary/{docId} {
      allow read: if isOwnerUid(userId);
      allow write: if false;
    }

    /** Taktik Muhabere — kişisel mesaj gizleme (karşı tarafı etkilemez) */
    match /users/{userId}/hidden_messages/{messageId} {
      allow read, create: if isOwnerUid(userId);
      allow update, delete: if false;
    }

    /** Taktik Muhabere — kişisel kanal arşivleme (karşı tarafı etkilemez) */
    match /users/{userId}/archived_channels/{channelId} {
      allow read, create, delete: if isOwnerUid(userId);
      allow update: if false;
    }

    match /users/{userId}/deleted_channels/{channelId} {
      allow read, create, delete: if isOwnerUid(userId);
      allow update: if false;
    }

    match /users/{userId}/archived_dms/{peerUid} {
      allow read, create, delete: if isOwnerUid(userId);
      allow update: if false;
    }

    match /users/{userId}/deleted_dms/{peerUid} {
      allow read, create, delete: if isOwnerUid(userId);
      allow update: if false;
    }

    /** @deprecated hidden_channels — archived_channels ile değiştirildi */
    match /users/{userId}/hidden_channels/{channelId} {
      allow read, create, delete: if isOwnerUid(userId);
      allow update: if false;
    }

    match /users/{userId}/system_alert_acks/{alertId} {
      allow read, list, create, update: if isOwnerUid(userId);
      allow delete: if isContentAdmin();
    }

    /**
     * usernames/{normalizedKey} — tek alan: uid (kayıt sırasında benzersiz kullanıcı adı).
     * get: kayıt öncesi müsaitlik kontrolü için herkese açık (yalnızca var/yok).
     * create: yalnızca kendi uid’si ile; silme: yalnızca sahibi (ileride kullanıcı adı değişiminde).
     */
    match /usernames/{uname} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /inventory/{userId} {
      allow read, write: if isOwnerUid(userId);
    }

    match /inventory/{userId}/items/{itemId} {
      allow read, write: if isOwnerUid(userId);
    }

    match /health_records/{userId} {
      allow read, write: if isOwnerUid(userId);
    }

    match /health_records/{userId}/records/{recordId} {
      allow read, write: if isOwnerUid(userId);
    }

    match /casualty_cards/{userId} {
      allow read, write: if isOwnerUid(userId);
    }

    match /casualty_cards/{userId}/cards/{cardId} {
      allow read, write: if isOwnerUid(userId);
    }

    match /ifak_inventory/{userId} {
      allow read, write: if isOwnerUid(userId);
    }

    match /ifak_inventory/{userId}/items/{itemId} {
      allow read, write: if isOwnerUid(userId);
    }

    match /medevac_logs/{userId} {
      allow read, write: if isOwnerUid(userId);
    }

    match /medevac_logs/{userId}/logs/{logId} {
      allow read, write: if isOwnerUid(userId);
    }

    /**
     * range_logs/{uid}/entries — atış günlüğü (Antrenman).
     * inventory/{uid}/items ile aynı model: yol üzerinden sahiplik (isOwnerUid).
     * Not: resource.data.ownerId şartı + orderBy sorgusu Firestore’da permission-denied üretebilir;
     * ownerId uygulama tarafında injectAudazCreateFields ile yazılmaya devam eder.
     */
    match /range_logs/{userId} {
      allow read, write: if canAccessOperatorData(userId);
    }

    match /range_logs/{userId}/entries/{entryId} {
      allow read, write: if canAccessOperatorData(userId);
    }

    match /vbss_logs/{userId} {
      allow read, write: if canAccessOperatorData(userId);
    }

    function validVbssObservedEvalCreate() {
      let d = request.resource.data;
      return d.kind == 'VBSS_OBSERVED_EVAL'
        && d.type == 'observed_evaluation'
        && d.userId == request.auth.uid
        && d.recordSource == 'self_entry'
        && d.verificationStatus == 'unverified'
        && d.observationMethod == 'peer_observed'
        && d.observerName is string
        && d.observerName.size() > 0
        && d.observedAt is string
        && d.observedAt.size() > 0
        && d.overallScore is number
        && d.successPercent is number
        && d.trainingType == 'INDIVIDUAL'
        && d.operationCategory == 'vbss'
        && d.discipline == 'vbss';
    }

    function validTcccObservedEvalCreate() {
      let d = request.resource.data;
      return d.kind == 'TCCC_OBSERVED_EVAL'
        && d.type == 'observed_evaluation'
        && d.userId == request.auth.uid
        && d.recordSource == 'self_entry'
        && d.verificationStatus == 'unverified'
        && d.observationMethod == 'peer_observed'
        && d.observerName is string
        && d.observerName.size() > 0
        && d.observedAt is string
        && d.observedAt.size() > 0
        && d.overallScore is number
        && d.successPercent is number
        && d.trainingType == 'INDIVIDUAL'
        && d.operationCategory == 'tccc'
        && d.discipline == 'tccc';
    }

    match /vbss_logs/{userId}/entries/{entryId} {
      allow read: if canAccessOperatorData(userId);
      allow create: if isOwnerUid(userId) && (
        request.resource.data.get('kind', '') != 'VBSS_OBSERVED_EVAL'
        || validVbssObservedEvalCreate()
      );
      allow update, delete: if canAccessOperatorData(userId);
    }

    match /tccc_logs/{userId} {
      allow read, write: if canAccessOperatorData(userId);
    }

    match /tccc_logs/{userId}/entries/{entryId} {
      allow read: if canAccessOperatorData(userId);
      allow create: if isOwnerUid(userId) && (
        request.resource.data.get('kind', '') != 'TCCC_OBSERVED_EVAL'
        || validTcccObservedEvalCreate()
      );
      allow update, delete: if canAccessOperatorData(userId);
    }

    match /armory_audit_trail/{userId} {
      allow read, write: if isOwnerUid(userId);
    }

    match /armory_audit_trail/{userId}/entries/{entryId} {
      allow read, write: if isOwnerUid(userId);
    }

    match /missions/{missionId} {
      allow read: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.visibility == 'org' ||
        ('assigneeIds' in resource.data.keys() && request.auth.uid in resource.data.assigneeIds)
      );
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /trainings/{trainingId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    /**
     * doktrinler — Landing (anonim) yalnızca isPublic == true okur;
     * oturum açmış operatörler tüm doktrinleri okuyabilir (Akademi).
     * Yazma / silme yalnızca isContentAdmin().
     */
    match /doktrinler/{docId} {
      allow read: if resource.data.isPublic == true || isSignedIn();
      allow create, update, delete: if isContentAdmin();
    }

    match /egitim_videolari/{docId} {
      allow read: if isSignedIn();
      allow create, delete: if isContentAdmin();
      allow update: if isContentAdmin();
    }

    /**
     * news_feed — küresel taktik/askeri istihbarat akışı (salt okunur operatör görünümü).
     */
    match /news_feed/{itemId} {
      allow read, list: if true;
      allow create, update, delete: if isContentAdmin();
    }

    /**
     * video_news — Defense News video RSS akışı (salt okunur operatör görünümü).
     */
    match /video_news/{itemId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isContentAdmin();
    }

    /**
     * system_alerts — zorunlu onay gerektiren komuta merkezi ikazları.
     */
    match /system_alerts/{alertId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isContentAdmin();

      match /receipts/{receiptUid} {
        allow read, list: if isContentAdmin();
        allow get: if isOwnerUid(receiptUid) || isContentAdmin();
        allow create, update: if isOwnerUid(receiptUid)
          && request.resource.data.uid == receiptUid
          && request.resource.data.alertId == alertId;
        allow delete: if isContentAdmin();
      }
    }

    /**
     * manual_alert_broadcasts — admin manuel ikaz yayın günlüğü.
     */
    match /manual_alert_broadcasts/{broadcastId} {
      allow read, list: if isSignedIn();
      allow create: if isContentAdmin();
      allow update: if false;
      allow delete: if isContentAdmin();
    }

    /**
     * youtube_channels — Küresel Haber Ağı video RSS kaynakları (admin yönetimi).
     */
    match /youtube_channels/{channelDocId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isContentAdmin();
    }

    match /envanter/{itemId} {
      allow read: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || isContentAdmin()
      );
      allow create: if isContentAdmin() || (
        isSignedIn() && request.resource.data.ownerId == request.auth.uid
      );
      allow update, delete: if isContentAdmin() || (
        isSignedIn() && resource.data.ownerId == request.auth.uid
      );
    }

    /**
     * instructor_tokens/{tokenId} — tek kullanımlık eğitmen davetiye kodu.
     * Belge kimliği = token dizesi (örn. AUDAZ-X97B-42KL).
     * get: kayıt öncesi doğrulama (kod gizli kalır, tahmin edilmesi zor).
     * create: yalnızca sistem yöneticisi (Ayarlar paneli).
     * update: yalnızca yeni kayıt olan kullanıcı kendi uid ile yakma (isUsed).
     */
    match /instructor_tokens/{tokenId} {
      allow get: if true;
      allow list: if isContentAdmin();
      allow create: if isContentAdmin()
        && request.resource.data.token == tokenId
        && request.resource.data.isUsed == false
        && request.resource.data.usedBy == null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * access_codes/{codeId} — Premium / Pro-Eğitmen çok-kişilik erişim kodu (3. bağımsız sistem).
     * Kullanım (redeem) yalnızca redeemAccessCode Cloud Function ile.
     */
    match /access_codes/{codeId} {
      allow get, list: if isContentAdmin();
      allow create: if isContentAdmin()
        && request.resource.data.code == codeId
        && request.resource.data.usedCount == 0
        && request.resource.data.status == 'active';
      allow update: if isContentAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'revokedAt', 'revokedBy', 'updatedAt'
        ])
        && request.resource.data.status == 'revoked';
      allow delete: if false;
    }

    /**
     * access_code_redemptions/{redemptionId} — audit trail (yalnızca Cloud Function yazar).
     */
    match /access_code_redemptions/{redemptionId} {
      allow get: if isContentAdmin()
        || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow list: if isContentAdmin();
      allow create, update, delete: if false;
    }

    match /instructorLogs/{logId} {
      allow create: if isInstructor() || isContentAdmin();
      allow read: if isContentAdmin() || isInstructor();
      allow update, delete: if false;
    }

    function groupDoc(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId));
    }

    function isGroupInstructor(groupId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && groupDoc(groupId).data.instructorId == request.auth.uid;
    }

    function isGroupMember(groupId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && request.auth.uid in groupDoc(groupId).data.members;
    }

    function canReadGroupDoc(groupId) {
      return isContentAdmin()
        || isGroupInstructor(groupId)
        || isGroupMember(groupId);
    }

    /** Operatör yalnızca kendi UID'sini members dizisine ekleyebilir; başka alan değişmez. */
    function isGroupMemberSelfJoin() {
      let prior = resource.data.get('members', []);
      let next = request.resource.data.get('members', []);
      return isSignedIn()
        && !(request.auth.uid in prior)
        && request.auth.uid in next
        && next.hasAll(prior)
        && next.size() == prior.size() + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']);
    }

    /**
     * groups/{groupId} — eğitmen oluşturur; operatör katılımı Cloud Function ile doğrulanır.
     */
    match /groups/{groupId} {
      allow get: if canReadGroupDoc(groupId);
      allow list: if isSignedIn() && (
        resource.data.instructorId == request.auth.uid
        || request.auth.uid in resource.data.members
      );
      allow create: if isSignedIn()
        && (isInstructor() || isContentAdmin())
        && request.resource.data.instructorId == request.auth.uid
        && request.resource.data.groupId == groupId
        && request.resource.data.members is list;
      allow update: if isSignedIn() && (
        resource.data.instructorId == request.auth.uid
        || isGroupMemberSelfJoin()
      );
      allow delete: if isSignedIn()
        && (resource.data.instructorId == request.auth.uid || isContentAdmin());
    }

    function canReadGroupAcademic(groupId) {
      return isGroupInstructor(groupId) || isGroupMember(groupId) || isContentAdmin();
    }

    /** Operatör profil groupId'si allowedGroups içindeyse çapraz grup oturumları okunabilir. */
    function operatorProfileGroupId() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('groupId', '')
        : '';
    }

    function isAllowedGroupTrainingParticipant() {
      let gid = operatorProfileGroupId();
      return gid != ''
        && gid in resource.data.get('allowedGroups', [])
        && isGroupMember(gid);
    }

    function canReadGroupTraining() {
      return canReadGroupAcademic(resource.data.groupId)
        || isAllowedGroupTrainingParticipant();
    }

    /** Karşı tarafın contacts dizisine yalnızca kendi UID eklenir (tim eşleşmesi). */
    function isMuhaberePeerContactLink(targetUid) {
      let prior = resource.data.get('contacts', []);
      let next = request.resource.data.get('contacts', []);
      return isSignedIn()
        && request.auth.uid != targetUid
        && isAuthMuhabereVisibleUser()
        && request.writeFields.hasOnly(['contacts'])
        && next.hasAll(prior)
        && next.size() == prior.size() + 1
        && request.auth.uid in next
        && !(request.auth.uid in prior);
    }

    /** Karşı tarafın contacts dizisinden yalnızca kendi UID çıkarılır (bağlantı koparma). */
    function isMuhaberePeerContactUnlink(targetUid) {
      let prior = resource.data.get('contacts', []);
      let next = request.resource.data.get('contacts', []);
      return isSignedIn()
        && request.auth.uid != targetUid
        && isAuthMuhabereVisibleUser()
        && request.writeFields.hasOnly(['contacts'])
        && prior.hasAll(next)
        && prior.size() == next.size() + 1
        && request.auth.uid in prior
        && !(request.auth.uid in next);
    }

    /** chats/{uidA}_{uidB} — katılımcı doğrulama */
    function isChatParticipant(chatId) {
      return isSignedIn()
        && (chatId.matches('^' + request.auth.uid + '_.*')
          || chatId.matches('.*_' + request.auth.uid + '$'));
    }

    /**
     * Mesaj okuma: sohbet katılımcısı veya alıcı (collectionGroup unread sorgusu).
     * Yalnızca isChatParticipant, receiverId+status collectionGroup listesini reddeder.
     */
    function canReadMuhabereMessage(chatId) {
      return isChatParticipant(chatId)
        || (isSignedIn() && resource.data.receiverId == request.auth.uid);
    }

    function isChannelMember(channelId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/channels/$(channelId))
        && request.auth.uid in get(/databases/$(database)/documents/channels/$(channelId)).data.members;
    }

    function muhabereDmMessageType() {
      return request.resource.data.get('type', 'text');
    }

    function isValidMuhabereDmMessageCreate() {
      let t = muhabereDmMessageType();
      return request.resource.data.senderId == request.auth.uid
        && request.resource.data.receiverId is string
        && request.resource.data.status == 'sent'
        && request.resource.data.read == false
        && (
          (t == 'text'
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 4000)
          || (t == 'image'
            && request.resource.data.imageUrl is string
            && request.resource.data.imageUrl.size() > 0
            && request.resource.data.imageUrl.size() <= 2048)
          || (t == 'location'
            && request.resource.data.lat is number
            && request.resource.data.lng is number)
        );
    }

    function isValidChannelMessageCreate(cid) {
      let t = request.resource.data.get('type', 'text');
      return request.resource.data.senderId == request.auth.uid
        && request.resource.data.channelId == cid
        && (
          (t == 'text'
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 4000)
          || (t == 'image'
            && request.resource.data.imageUrl is string
            && request.resource.data.imageUrl.size() > 0)
          || (t == 'location'
            && request.resource.data.lat is number
            && request.resource.data.lng is number)
        );
    }

    /**
     * group_training_templates — eğitmen tanımlı akademik drill şablonları.
     */
    match /group_training_templates/{templateId} {
      allow read: if canReadGroupAcademic(resource.data.groupId);
      allow list: if isInstructor() || isContentAdmin();
      allow create: if isInstructor()
        && request.resource.data.instructorId == request.auth.uid
        && isGroupInstructor(request.resource.data.groupId)
        && request.resource.data.templateId == templateId;
      allow update, delete: if isInstructor()
        && resource.data.instructorId == request.auth.uid
        && isGroupInstructor(resource.data.groupId);
    }

    /**
     * group_activity_logs — eğitmen onaylı grup eğitim skorları (range_logs’tan izole).
     */
    match /group_activity_logs/{logId} {
      allow read: if canReadGroupAcademic(resource.data.groupId);
      allow list: if isInstructor() || isContentAdmin()
        || (isSignedIn() && canReadGroupAcademic(resource.data.groupId));
      allow create: if (
        isInstructor()
        && request.resource.data.instructorId == request.auth.uid
        && request.resource.data.type == 'group_drill'
        && isGroupInstructor(request.resource.data.groupId)
        && request.resource.data.logId == logId
      ) || (
        isInstructor()
        && request.resource.data.instructorId == request.auth.uid
        && request.resource.data.type == 'group_training_result'
        && request.resource.data.trainingType == 'GROUP'
        && request.resource.data.sourceDomain == 'group_trainings'
        && request.resource.data.operatorSubmitted == true
        && request.resource.data.logId == logId
        && request.resource.data.groupId is string
        && request.resource.data.operatorId is string
        && isGroupInstructor(request.resource.data.groupId)
      ) || (
        isSignedIn()
        && request.resource.data.type == 'operator_group_feed'
        && request.resource.data.trainingType == 'GROUP'
        && request.resource.data.operatorId == request.auth.uid
        && request.resource.data.logId == logId
        && isGroupMember(request.resource.data.groupId)
        && request.resource.data.instructorId == groupDoc(request.resource.data.groupId).data.instructorId
      );
      allow update, delete: if false;
    }

    /**
     * drill_templates — eğitmen atış drill kütüphanesi.
     */
    match /drill_templates/{templateId} {
      allow read: if isSignedIn()
        && resource.data.instructorId == request.auth.uid;
      allow list: if isInstructor() || isContentAdmin();
      allow create: if isInstructor()
        && request.resource.data.instructorId == request.auth.uid
        && request.resource.data.id == templateId;
      allow update, delete: if isInstructor()
        && resource.data.instructorId == request.auth.uid;
    }

    /**
     * group_trainings — eğitmen açtığı canlı grup eğitim oturumları.
     */
    match /group_trainings/{trainingId} {
      allow read: if canReadGroupTraining();
      allow list: if isInstructor() || isContentAdmin()
        || (isSignedIn() && canReadGroupTraining());
      allow create: if isInstructor()
        && request.resource.data.instructorId == request.auth.uid
        && request.resource.data.id == trainingId
        && isGroupInstructor(request.resource.data.groupId)
        && request.resource.data.status == 'active';
      allow update: if isInstructor()
        && resource.data.instructorId == request.auth.uid
        && isGroupInstructor(resource.data.groupId)
        && resource.data.status == 'active'
        && request.resource.data.status == 'completed'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if false;
    }

    /**
     * vbss_evaluations — eğitmen gemi operasyonu değerlendirme formu.
     */
    match /vbss_evaluations/{evaluationId} {
      allow read: if canReadGroupAcademic(resource.data.groupId);
      allow list: if isInstructor() || isContentAdmin()
        || (isSignedIn() && canReadGroupAcademic(resource.data.groupId));
      allow create: if isInstructor()
        && request.resource.data.instructorId == request.auth.uid
        && request.resource.data.id == evaluationId
        && request.resource.data.type == 'vbss_evaluation'
        && request.resource.data.discipline == 'vbss'
        && isGroupInstructor(request.resource.data.groupId)
        && request.resource.data.operatorId is string
        && request.resource.data.overallScore is number;
      allow update, delete: if false;
    }

    /**
     * tccc_evaluations — eğitmen MARCH taktik tıbbi değerlendirme formu.
     */
    match /tccc_evaluations/{evaluationId} {
      allow read: if canReadGroupAcademic(resource.data.groupId);
      allow list: if isInstructor() || isContentAdmin()
        || (isSignedIn() && canReadGroupAcademic(resource.data.groupId));
      allow create: if isInstructor()
        && request.resource.data.instructorId == request.auth.uid
        && request.resource.data.id == evaluationId
        && request.resource.data.type == 'tccc_evaluation'
        && request.resource.data.discipline == 'tccc'
        && isGroupInstructor(request.resource.data.groupId)
        && request.resource.data.operatorId is string
        && request.resource.data.overallScore is number;
      allow update, delete: if false;
    }

    /**
     * training_results — operatör vuruş/süre girişleri.
     */
    match /training_results/{resultId} {
      allow read: if canReadGroupAcademic(resource.data.groupId);
      allow list: if isInstructor() || isContentAdmin()
        || (isSignedIn() && canReadGroupAcademic(resource.data.groupId));
      allow create: if isSignedIn()
        && request.resource.data.id == resultId
        && request.resource.data.operatorId == request.auth.uid
        && isGroupMember(request.resource.data.groupId)
        && request.resource.data.hits is number
        && request.resource.data.hits >= 0;
      allow update, delete: if false;
    }

    /**
     * sitrep_posts — modül kaldırıldı; tüm erişim kapalı.
     */
    match /sitrep_posts/{document=**} {
      allow read, write: if false;
    }

    /**
     * egitim_videolari — Audaz Akademi (operatör okuma).
     */
    match /egitim_videolari/{document=**} {
      allow read: if request.auth != null;
    }

    /** forum_posts — likes dizisinde yalnızca kendi UID eklenir / çıkarılır */
    function isForumLikeToggle() {
      let prior = resource.data.get('likes', []);
      let next = request.resource.data.get('likes', []);
      return isSignedIn()
        && request.writeFields.hasOnly(['likes'])
        && next is list
        && (
          (
            request.auth.uid in next
            && !(request.auth.uid in prior)
            && next.size() == prior.size() + 1
          )
          || (
            !(request.auth.uid in next)
            && request.auth.uid in prior
            && next.size() == prior.size() - 1
          )
        );
    }

    function isForumSoftRemovePayload() {
      return request.resource.data.removed == true
        && request.resource.data.removedReason is string
        && request.resource.data.removedBy == request.auth.uid
        && request.resource.data.removedAt == request.time;
    }

    function isForumPostSoftRemoveUpdate() {
      return isContentAdmin()
        && request.writeFields.hasOnly(['removed', 'removedReason', 'removedBy', 'removedAt'])
        && isForumSoftRemovePayload();
    }

    function isForumReplySoftRemoveUpdate() {
      return isForumPostSoftRemoveUpdate();
    }

    function isValidForumReportReason(reason) {
      return reason == 'spam'
        || reason == 'harassment'
        || reason == 'inappropriate'
        || reason == 'other';
    }

    function isValidForumReportCreate(reportId) {
      let d = request.resource.data;
      let uid = request.auth.uid;
      return d.reporterId == uid
        && (d.targetType == 'post' || d.targetType == 'comment')
        && d.targetId is string
        && d.targetId.size() > 0
        && isValidForumReportReason(d.reason)
        && d.status == 'pending'
        && d.createdAt == request.time
        && (d.description == null || (d.description is string && d.description.size() <= 500))
        && d.reporterCallsign is string
        && (
          (
            d.targetType == 'post'
            && (!('parentPostId' in d) || d.parentPostId == null)
            && reportId == 'post_' + d.targetId + '_' + uid
          )
          || (
            d.targetType == 'comment'
            && d.parentPostId is string
            && d.parentPostId.size() > 0
            && reportId == 'comment_' + d.parentPostId + '_' + d.targetId + '_' + uid
          )
        );
    }

    /**
     * forum_posts — Brifing Odası (başlıklar, mutabık, yanıtlar).
     */
    match /forum_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.content is string;
      allow update: if isSignedIn() && (
        isForumLikeToggle()
        || (
          request.writeFields.hasOnly(['replyCount'])
          && request.resource.data.replyCount == resource.data.replyCount + 1
        )
        || isForumPostSoftRemoveUpdate()
      );
      allow delete: if isContentAdmin()
        || (isSignedIn() && resource.data.authorId == request.auth.uid);

      match /replies/{replyId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.content is string;
        allow update: if isForumReplySoftRemoveUpdate();
        allow delete: if false;
      }
    }

    /** forum_reports belge kimliği son segmenti reporter UID (createForumReport / buildForumReportId). */
    function isOwnForumReportId(reportId) {
      return isSignedIn() && reportId.matches('.*_' + request.auth.uid + '$');
    }

    /**
     * forum_reports — Brifing Odası kullanıcı şikayetleri.
     * Belge kimliği: post_{targetId}_{reporterId} | comment_{parentPostId}_{targetId}_{reporterId}
     */
    match /forum_reports/{reportId} {
      allow create: if isSignedIn() && isValidForumReportCreate(reportId);
      allow get: if isContentAdmin() || isOwnForumReportId(reportId);
      allow list, update: if isContentAdmin();
      allow delete: if false;
    }

    /**
     * contact_requests — tim / irtibat istekleri (Forum + Taktik Muhabere).
     * Belge kimliği: {senderId}_{receiverId}
     * senderId = from, receiverId = to
     */
    match /contact_requests/{requestId} {
      // Tek belge okuma: belge yokken de gönderen/alıcı requestId ile erişebilir
      allow get: if isSignedIn()
        && (
          requestId.matches('^' + request.auth.uid + '_.*')
          || requestId.matches('.*_' + request.auth.uid + '$')
        );
      // Sorgu okuma: where senderId / receiverId filtreleri
      allow list: if isSignedIn()
        && (
          resource.data.senderId == request.auth.uid
          || resource.data.receiverId == request.auth.uid
        );
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.receiverId is string
        && request.resource.data.receiverId != request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isSignedIn()
        && resource.data.receiverId == request.auth.uid;
      allow delete: if isSignedIn()
        && (
          resource.data.senderId == request.auth.uid
          || resource.data.receiverId == request.auth.uid
        );
    }

    /**
     * conversations — Muhabere özet belgeleri (lastMessage, lastSender, unreadByUser).
     */
    match /conversations/{conversationId} {
      allow get: if isSignedIn()
        && request.auth.uid in resource.data.members;
      allow list: if isSignedIn()
        && request.auth.uid in resource.data.members;

      allow create: if isSignedIn()
        && request.resource.data.type in ['channel', 'dm']
        && request.resource.data.refId is string
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members;

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.members
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unreadByUser']);

      allow delete: if false;
    }

    /**
     * chats/{chatId}/messages — Taktik Muhabere DM (chatId = küçükUID_büyükUID)
     */
    match /chats/{chatId} {
      allow read: if isChatParticipant(chatId);
      allow create: if isChatParticipant(chatId);
      allow update: if isChatParticipant(chatId);
      allow delete: if false;

      match /messages/{messageId} {
        allow get: if canReadMuhabereMessage(chatId);
        /** Katılımcı tüm DM geçmişini dinleyebilir; unread sorgusu receiverId ile filtrelenir. */
        allow list: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId) && isValidMuhabereDmMessageCreate() && isNotSuspended();
        allow update: if isChatParticipant(chatId)
          && isMuhabereMessageMarkedReadByReceiver();
        allow delete: if isChatParticipant(chatId)
          && resource.data.isBurn == true;
      }
    }

    /**
     * channels — Taktik Muhabere tim kanalları (grup sohbeti).
     * list: members array-contains sorgusu için resource.data kullanılmalı (get() list'te reddedilir).
     */
    match /channels/{channelId} {
      allow get: if isChannelMember(channelId);
      allow list: if isSignedIn() && request.auth.uid in resource.data.get('members', []);
      allow create: if isSignedIn()
        && isAuthMuhabereVisibleUser()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 64
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members;
      allow update: if isChannelMember(channelId)
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isChannelMember(channelId);
        allow create: if isChannelMember(channelId) && isValidChannelMessageCreate(channelId) && isNotSuspended();
        allow update, delete: if false;
      }
    }

    /**
     * notifications — platform geneli merkezi bildirimler.
     * recipientId: alıcı UID, type: LIKE | COMMENT | FRIEND_REQUEST | TRAINING | ACADEMY | SYSTEM
     */
    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.recipientId == request.auth.uid;
      allow list: if isSignedIn()
        && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.recipientId is string
        && request.resource.data.type is string
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.isRead == false
        && request.resource.data.link is string;
      allow update: if isSignedIn()
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
        && request.resource.data.isRead is bool;
      allow delete: if false;
    }

    /**
     * feedback — operatör geri bildirimleri (hata / öneri / bug + şikayet & öneri).
     */
    match /feedback/{feedbackId} {
      allow create: if isSignedIn()
        && isNotSuspended()
        && request.resource.data.userId == request.auth.uid
        && (
          (
            request.resource.data.issueType in ['Hata', 'Öneri', 'Bug']
            && request.resource.data.description is string
            && request.resource.data.description.size() > 0
            && request.resource.data.description.size() <= 4000
            && (
              !('screenshotURL' in request.resource.data)
              || (
                request.resource.data.screenshotURL is string
                && request.resource.data.screenshotURL.size() <= 2048
              )
            )
          )
          || (
            request.resource.data.type in ['complaint', 'suggestion']
            && request.resource.data.fullName is string
            && request.resource.data.fullName.size() > 0
            && request.resource.data.fullName.size() <= 120
            && request.resource.data.subject is string
            && request.resource.data.subject.size() > 0
            && request.resource.data.subject.size() <= 200
            && request.resource.data.message is string
            && request.resource.data.message.size() > 0
            && request.resource.data.message.size() <= 4000
            && request.resource.data.status == 'new'
            && request.resource.data.imageUrls is list
            && request.resource.data.imageUrls.size() <= 5
          )
        );
      allow read, list: if isContentAdmin();
      allow update, delete: if isContentAdmin();
    }

    /**
     * suspensionAppeals — askıdaki kullanıcı itirazları (yalnızca create açık).
     */
    match /suspensionAppeals/{appealId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userEmail is string
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000
        && request.resource.data.status == 'pending'
        && request.resource.data.suspensionReasonSnapshot is string
        && request.resource.data.suspensionReasonSnapshot.size() <= 500;
      allow read: if isContentAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isContentAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
