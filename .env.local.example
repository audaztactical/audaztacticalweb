# Firebase Console → Project Settings → Your apps → Web app
# Vercel deploy: aynı VITE_FIREBASE_* değişkenlerini Vercel → Settings → Environment Variables'a ekleyin
# (inject-fcm-sw.mjs build sırasında process.env'den okur; yalnızca .env.local yetmez)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=audaz-web.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=audaz-web
VITE_FIREBASE_STORAGE_BUCKET=audaz-web.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Console → Cloud Messaging → Web Push certificates → Key pair
# 1. Firebase Console → Project Settings (dişli) → Cloud Messaging sekmesi
# 2. "Web configuration" → "Generate key pair" (veya mevcut Key pair'i kopyala)
# 3. Aşağıya yapıştır; ardından npm run dev / build yeniden başlat
VITE_FIREBASE_VAPID_KEY=

# Platform lansman tarihi (beta bitişi — ISO 8601)
VITE_PLATFORM_LAUNCH_ISO=2026-07-07T00:00:00+03:00

# Admin panel erişimi
VITE_ADMIN_EMAIL=

# Cloud Functions (varsayılan: us-central1)
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Yerel emulator — functions klasöründe: npm run serve
# VITE_FUNCTIONS_EMULATOR=true
# VITE_FUNCTIONS_EMULATOR_HOST=127.0.0.1
# VITE_FUNCTIONS_EMULATOR_PORT=5001

# Girişte ensureAdminClaim çağrısı — yalnızca Functions ADMIN_EMAIL ayarlandıktan sonra gerekir
# VITE_SYNC_ADMIN_CLAIM_ON_LOGIN=true
