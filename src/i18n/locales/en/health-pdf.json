  "nineLine": {
    "sectionTitle": "9-Line Evacuation Protocol",
    "lines": {
      "1": {
        "label": "Location (MGRS/GPS)",
        "note": "Enter the exact pickup-point coordinates. MGRS format preferred. E.g.: 37S NA 12345 67890"
      },
      "2": {
        "label": "Radio frequency and callsign",
        "note": "Frequency (MHz) and callsign for contact with the evacuation platform. E.g.: 40.50 MHz · BRAVO-1"
      },
      "3": {
        "label": "Number of patients by precedence",
        "note": "A=Urgent (life-threatening), B=Priority (within 1 hour), C=Routine (within 4 hours). E.g.: 2A 1B"
      },
      "4": {
        "label": "Special equipment required",
        "note": "A=None, B=Hoist, C=Extraction equipment, D=Ventilator, E=Other"
      },
      "5": {
        "label": "Number of patients (litter / ambulatory)",
        "note": "L=Litter, A=Ambulatory. E.g.: 1L 2A"
      },
      "6": {
        "label": "Security at pickup site",
        "note": "N=No enemy troops in area, P=Possible enemy troops, E=Enemy troops in area, X=Armed escort required"
      },
      "7": {
        "label": "Method of marking pickup site",
        "note": "A=Panels, B=Pyrotechnic, C=Smoke, D=None, E=Other. Specify color when applicable."
      },
      "8": {
        "label": "Patient nationality / status",
        "note": "Civilian=Civilian, Military=Friendly force, EPW=Enemy Prisoner of War",
        "options": {
          "civilian": "Civilian",
          "military": "Military",
          "epw": "EPW"
        }
      },
      "9": {
        "label": "NBC contamination / terrain",
        "note": "Obstacles at the LZ: trees, wires, slope, elevation, etc. Include wind direction."
      }
    },
    "abbreviations": [
      "MGRS: Military Grid Reference System",
      "MEDEVAC: Medical Evacuation",
      "EPW: Enemy Prisoner of War",
      "Precedence: A=Urgent (<1 hr) · B=Priority (<4 hr) · C=Routine (<24 hr)",
      "After completion this form is read over the radio; a copy stays with the carried patient"
    ]
  },
